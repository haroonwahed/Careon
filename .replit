modules = ["nodejs-20", "python-3.12", "web"]
run = "run"

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib", "zip"]

[deployment]
run = ["sh", "-c", "run"]

[workflows]
runButton = "Django Server"

[[workflows.workflow]]
name = "Full Stack Dev"
author = 40360714
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python manage.py migrate && python manage.py runserver 0.0.0.0:$PORT"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"No client directory found. Create client/ with npm init and vite setup first.\""

[[workflows.workflow]]
name = "Django + Vite"
author = 40360714
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python manage.py migrate && python manage.py runserver 0.0.0.0:$PORT"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd client && npm run dev -- --host 0.0.0.0 --port 5173"

[[workflows.workflow]]
name = "Django Server"
author = 40360714
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python manage.py runserver 0.0.0.0:8000"

[env]
PORT = "5000"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

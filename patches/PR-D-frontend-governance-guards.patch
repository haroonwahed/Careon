@@ -0,0 +1,118 @@
+#!/usr/bin/env python3
+"""Diff-scoped CareOn design-token governance for NEW/CHANGED frontend code.
+
+Reuses the canonical rule set from scripts/check_careon_design_tokens.py (no
+second rule list). Only ADDED lines (git diff vs a base ref) in
+client/src/**/*.{ts,tsx} are checked, so pre-existing offenders are grandfathered
+automatically. scripts/token_governance_allowlist.json records explicit
+per-(file,line) exceptions. Changes/migrates/deletes no components.
+
+Base resolution order:
+  1. explicit --base argument or TOKEN_GOVERNANCE_BASE env (the workflow passes
+     PR base SHA / event.before / origin/main here);
+  2. origin/main;
+  3. main;
+  4. none resolvable -> in CI: ERROR + exit 1; locally: WARNING + skip (exit 0).
+"""
+from __future__ import annotations
+
+import argparse
+import json
+import os
+import re
+import subprocess
+import sys
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parents[1]
+SCRIPTS = Path(__file__).resolve().parent
+sys.path.insert(0, str(SCRIPTS))
+from check_careon_design_tokens import RULES  # canonical rules, reused
+
+ALLOWLIST = SCRIPTS / "token_governance_allowlist.json"
+FE_PREFIX = "client/src/"
+FE_SUFFIX = (".ts", ".tsx")
+
+
+def _is_ci() -> bool:
+    return os.environ.get("CI", "").lower() == "true" or os.environ.get("GITHUB_ACTIONS", "").lower() == "true"
+
+
+def _ref_exists(ref: str) -> bool:
+    try:
+        subprocess.run(
+            ["git", "rev-parse", "--verify", "--quiet", ref + "^{commit}"],
+            cwd=ROOT, check=True, capture_output=True,
+        )
+        return True
+    except subprocess.CalledProcessError:
+        return False
+
+
+def _resolve_base(candidate: str):
+    for ref in (candidate, "origin/main", "main"):
+        if ref and _ref_exists(ref):
+            return ref
+    return None
+
+
+def _added_lines(base: str):
+    diff = subprocess.run(
+        ["git", "diff", "--unified=0", f"{base}...HEAD", "--", FE_PREFIX],
+        cwd=ROOT, capture_output=True, text=True, check=True,
+    ).stdout
+    cur = None
+    new_no = 0
+    for line in diff.splitlines():
+        if line.startswith("+++ b/"):
+            cur = line[6:]
+        elif line.startswith("@@"):
+            m = re.search(r"\+(\d+)", line)
+            new_no = int(m.group(1)) if m else 0
+        elif line.startswith("+") and not line.startswith("+++"):
+            if cur and cur.startswith(FE_PREFIX) and cur.endswith(FE_SUFFIX):
+                yield cur, new_no, line[1:]
+            new_no += 1
+
+
+def _allowlist() -> set:
+    if not ALLOWLIST.exists():
+        return set()
+    data = json.loads(ALLOWLIST.read_text(encoding="utf-8"))
+    return {(e["file"], e.get("line")) for e in data.get("allowed", [])}
+
+
+def main() -> int:
+    ap = argparse.ArgumentParser()
+    ap.add_argument("--base", default=os.environ.get("TOKEN_GOVERNANCE_BASE", "origin/main"))
+    args = ap.parse_args()
+
+    base = _resolve_base(args.base)
+    if not base:
+        msg = "design-token governance: could not resolve a diff base (tried explicit base, origin/main, main)."
+        if _is_ci():
+            print("ERROR: " + msg + " A base is required in CI; refusing to pass silently.")
+            return 1
+        print("WARNING: " + msg + " Skipping locally (exit 0).")
+        return 0
+
+    allow = _allowlist()
+    violations: list[str] = []
+    for path, line_no, text in _added_lines(base):
+        for rule in RULES:
+            for match in rule.pattern.finditer(text):
+                if (path, line_no) in allow or (path, None) in allow:
+                    continue
+                violations.append(f"{path}:{line_no} [{rule.severity}] {rule.name}: {match.group(0)}")
+    if violations:
+        print(f"FAIL: design-token violations in NEW/changed FE lines (base {base}):")
+        for v in violations:
+            print("  - " + v)
+        print("\nUse --care-* tokens / Tailwind theme keys. Pre-existing code is grandfathered (only added lines are checked).")
+        return 1
+    print(f"PASS: no token violations in added FE lines (base {base}).")
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
diff --git a/scripts/check_forbidden_component_imports.py b/scripts/check_forbidden_component_imports.py

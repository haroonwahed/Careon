+{
+  "description": "Grandfathered existing PRODUCTION imports of components whose governance status in docs/design/CAREON_COMPONENT_INVENTORY.md is Forbidden or Deprecated. The guard (scripts/check_forbidden_component_imports.py) derives the forbidden set from that canonical inventory; this file only records pre-existing importers to grandfather. Empty = no production importers exist today. Add entries only for a deliberate, separately-reported exception. Format: {\"importer\": \"client/src/...\", \"module\": \"<basename or inventory path>\", \"reason\": \"...\"}.",
+  "allowed_imports": []
+}

index 0000000..f455ded
--- /dev/null
+++ b/scripts/check_forbidden_component_imports.py
@@ -0,0 +1,119 @@
+#!/usr/bin/env python3
+"""Guard: block NEW imports of components marked Forbidden/Deprecated.
+
+Single source of truth: docs/design/CAREON_COMPONENT_INVENTORY.md (the canonical
+component register). This guard introduces NO second component list — it derives
+the forbidden/deprecated set from that document's governance entries (any line
+that names a `client/src/...tsx?` path and the word "Forbidden" or "Deprecated").
+
+Pre-existing, deliberate importers are grandfathered via
+scripts/forbidden_import_allowlist.json (machine-readable). The guard fails only
+on a NEW (non-allowlisted) production import. Test/spec/story files are not
+scanned. It moves, migrates, or deletes no components.
+"""
+from __future__ import annotations
+
+import json
+import re
+import sys
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parents[1]
+INVENTORY = ROOT / "docs" / "design" / "CAREON_COMPONENT_INVENTORY.md"
+CLIENT_SRC = ROOT / "client" / "src"
+ALLOWLIST = Path(__file__).resolve().parent / "forbidden_import_allowlist.json"
+
+GOVERNANCE_KEYWORDS = ("Forbidden", "Deprecated")
+PATH_IN_BACKTICKS = re.compile(r"`(client/src/[^`]+?\.tsx?)`")
+IMPORT_SPEC = re.compile(
+    r"""(?:import|export)\b[^'"]*?from\s*['"]([^'"]+)['"]|import\(\s*['"]([^'"]+)['"]\s*\)"""
+)
+TEST_MARKERS = (".test.", ".spec.", "__tests__/", "/tests/", ".stories.")
+
+
+def forbidden_modules_from_inventory() -> dict:
+    out: dict[str, str] = {}
+    if not INVENTORY.exists():
+        return out
+    for line in INVENTORY.read_text(encoding="utf-8").splitlines():
+        if not any(k in line for k in GOVERNANCE_KEYWORDS):
+            continue
+        for m in PATH_IN_BACKTICKS.finditer(line):
+            path = m.group(1)
+            base = path.rsplit("/", 1)[-1].rsplit(".", 1)[0]
+            out[base] = path
+    return out
+
+
+def _spec_matches(spec: str, base: str, path: str) -> bool:
+    spec_noext = re.sub(r"\.tsx?$", "", spec)
+    if spec_noext == base or spec_noext.endswith("/" + base):
+        return True
+    tail = re.sub(r"\.tsx?$", "", path).split("client/src/", 1)[-1]
+    return spec_noext.endswith(tail)
+
+
+def iter_source_files():
+    if not CLIENT_SRC.exists():
+        return
+    for p in sorted(CLIENT_SRC.rglob("*")):
+        if p.suffix not in (".ts", ".tsx"):
+            continue
+        rel = p.relative_to(ROOT).as_posix()
+        if any(mark in rel for mark in TEST_MARKERS):
+            continue
+        yield p
+
+
+def load_allowlist() -> set:
+    if not ALLOWLIST.exists():
+        return set()
+    data = json.loads(ALLOWLIST.read_text(encoding="utf-8"))
+    return {(e["importer"], e["module"]) for e in data.get("allowed_imports", [])}
+
+
+def main() -> int:
+    if not INVENTORY.exists():
+        print(f"ERROR: canonical component inventory not found at {INVENTORY}.")
+        print("Cannot derive the Forbidden/Deprecated set; refusing to pass silently.")
+        return 1
+    forbidden = forbidden_modules_from_inventory()
+    if not forbidden:
+        print("No Deprecated or Forbidden components are currently registered.")
+        print("Nothing to enforce.")
+        return 0
+    allow = load_allowlist()
+    forbidden_paths = set(forbidden.values())
+    violations: list[str] = []
+    for p in iter_source_files():
+        rel = p.relative_to(ROOT).as_posix()
+        if rel in forbidden_paths:
+            continue
+        text = p.read_text(encoding="utf-8")
+        for m in IMPORT_SPEC.finditer(text):
+            spec = m.group(1) or m.group(2)
+            if not spec:
+                continue
+            for base, path in forbidden.items():
+                if _spec_matches(spec, base, path):
+                    if (rel, base) in allow or (rel, path) in allow:
+                        continue
+                    violations.append(
+                        f"{rel} imports forbidden/deprecated component '{base}' "
+                        f"(spec {spec!r}; inventory {path})"
+                    )
+    if violations:
+        print("FAIL: new imports of Forbidden/Deprecated components (governance in CAREON_COMPONENT_INVENTORY.md):")
+        for v in violations:
+            print("  - " + v)
+        print(
+            "\nImport the approved replacement primitive instead, or — for a deliberate, separately-"
+            "reported exception — add an entry to scripts/forbidden_import_allowlist.json."
+        )
+        return 1
+    print(f"PASS: no new imports of {len(forbidden)} Forbidden/Deprecated component(s).")
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())

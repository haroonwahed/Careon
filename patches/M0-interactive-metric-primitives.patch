+import { render, screen } from "@testing-library/react";
+import userEvent from "@testing-library/user-event";
+import * as React from "react";
+import { describe, expect, it, vi } from "vitest";
+import { CareInteractiveMetricCard, CareInteractiveMetricStrip } from "./CareDesignPrimitives";
+
+describe("CareInteractiveMetricCard", () => {
+  it("renders value and label (default render)", () => {
+    render(<CareInteractiveMetricCard value={12} label="Open aanvragen" />);
+    const btn = screen.getByRole("button");
+    expect(btn.textContent).toContain("12");
+    expect(btn.textContent).toContain("Open aanvragen");
+  });
+
+  it("reflects unpressed state via aria-pressed", () => {
+    render(<CareInteractiveMetricCard value={1} label="A" pressed={false} />);
+    expect(screen.getByRole("button").getAttribute("aria-pressed")).toBe("false");
+  });
+
+  it("reflects pressed state via aria-pressed", () => {
+    render(<CareInteractiveMetricCard value={1} label="A" pressed />);
+    expect(screen.getByRole("button").getAttribute("aria-pressed")).toBe("true");
+  });
+
+  it("calls onPressedChange with the toggled value on click", async () => {
+    const onPressedChange = vi.fn();
+    render(<CareInteractiveMetricCard value={1} label="A" pressed={false} onPressedChange={onPressedChange} />);
+    await userEvent.click(screen.getByRole("button"));
+    expect(onPressedChange).toHaveBeenCalledTimes(1);
+    expect(onPressedChange).toHaveBeenCalledWith(true);
+  });
+
+  it("activates exactly once on Enter (no double activation)", async () => {
+    const onPressedChange = vi.fn();
+    render(<CareInteractiveMetricCard value={1} label="A" onPressedChange={onPressedChange} />);
+    screen.getByRole("button").focus();
+    await userEvent.keyboard("{Enter}");
+    expect(onPressedChange).toHaveBeenCalledTimes(1);
+  });
+
+  it("activates exactly once on Space (no double activation)", async () => {
+    const onPressedChange = vi.fn();
+    render(<CareInteractiveMetricCard value={1} label="A" onPressedChange={onPressedChange} />);
+    screen.getByRole("button").focus();
+    await userEvent.keyboard(" ");
+    expect(onPressedChange).toHaveBeenCalledTimes(1);
+  });
+
+  it("is focusable", () => {
+    render(<CareInteractiveMetricCard value={1} label="A" />);
+    const btn = screen.getByRole("button");
+    btn.focus();
+    expect(document.activeElement).toBe(btn);
+  });
+
+  it("is disabled and fires zero callbacks when disabled (click + keyboard)", async () => {
+    const onPressedChange = vi.fn();
+    render(<CareInteractiveMetricCard value={1} label="A" disabled onPressedChange={onPressedChange} />);
+    const btn = screen.getByRole("button") as HTMLButtonElement;
+    expect(btn.disabled).toBe(true);
+    await userEvent.click(btn);
+    btn.focus();
+    await userEvent.keyboard("{Enter}");
+    await userEvent.keyboard(" ");
+    expect(onPressedChange).not.toHaveBeenCalled();
+  });
+});
+
+describe("CareInteractiveMetricStrip", () => {
+  it("renders multiple metric children", () => {
+    render(
+      <CareInteractiveMetricStrip cols={3}>
+        <CareInteractiveMetricCard value={1} label="A" />
+        <CareInteractiveMetricCard value={2} label="B" />
+        <CareInteractiveMetricCard value={3} label="C" />
+      </CareInteractiveMetricStrip>,
+    );
+    expect(screen.getAllByRole("button")).toHaveLength(3);
+  });
+
+  it("uses a static, safelistable column class per cols value", () => {
+    const { container, rerender } = render(
+      <CareInteractiveMetricStrip cols={2}><span /></CareInteractiveMetricStrip>,
+    );
+    expect((container.firstChild as HTMLElement).className).toContain("sm:grid-cols-2");
+    rerender(<CareInteractiveMetricStrip cols={3}><span /></CareInteractiveMetricStrip>);
+    expect((container.firstChild as HTMLElement).className).toContain("lg:grid-cols-3");
+    rerender(<CareInteractiveMetricStrip cols={4}><span /></CareInteractiveMetricStrip>);
+    expect((container.firstChild as HTMLElement).className).toContain("lg:grid-cols-4");
+  });
+});

+import type { Meta, StoryObj } from "@storybook/react";
+import { useState } from "react";
+import { CareInteractiveMetricCard, CareInteractiveMetricStrip } from "./CareDesignPrimitives";
+
+const meta: Meta<typeof CareInteractiveMetricCard> = {
+  title: "Care/CareInteractiveMetricCard",
+  component: CareInteractiveMetricCard,
+};
+export default meta;
+type Story = StoryObj<typeof CareInteractiveMetricCard>;
+
+export const Unselected: Story = { args: { value: 12, label: "Open aanvragen", tone: "neutral", pressed: false } };
+export const Selected: Story = { args: { value: 12, label: "Open aanvragen", tone: "neutral", pressed: true } };
+export const Warning: Story = { args: { value: 5, label: "SLA-risico", tone: "warning", pressed: false } };
+export const Urgent: Story = { args: { value: 3, label: "Overschreden", tone: "urgent", pressed: true } };
+export const Disabled: Story = { args: { value: 0, label: "Geen openstaand", tone: "neutral", disabled: true } };
+
+export const Strip: Story = {
+  render: () => {
+    const [active, setActive] = useState<string | null>("open");
+    const toggle = (id: string) => setActive((cur) => (cur === id ? null : id));
+    return (
+      <CareInteractiveMetricStrip cols={3}>
+        <CareInteractiveMetricCard value={12} label="Open" tone="neutral" pressed={active === "open"} onPressedChange={() => toggle("open")} />
+        <CareInteractiveMetricCard value={5} label="SLA-risico" tone="warning" pressed={active === "sla"} onPressedChange={() => toggle("sla")} />
+        <CareInteractiveMetricCard value={3} label="Overschreden" tone="urgent" pressed={active === "od"} onPressedChange={() => toggle("od")} />
+      </CareInteractiveMetricStrip>
+    );
+  },
+};
